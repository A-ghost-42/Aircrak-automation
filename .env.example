# Pegasus-Nexus Configuration
# Copy to .env and adjust for your environment

# Network interface (default: wlan0)
PEGASUS_INTERFACE=wlan0

# Output directory for reports (default: .)
PEGASUS_OUTPUT_DIR=./reports

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
PEGASUS_LOG_LEVEL=INFO

# Log file path (default: pegasus_nexus.log)
PEGASUS_LOG_FILE=pegasus_nexus.log

# Max log size in MB before rotation (default: 10)
PEGASUS_LOG_MAX_MB=10

# Max backup log files to keep (default: 5)
PEGASUS_LOG_BACKUPS=5

# Attack timeout per target in seconds (default: 3600)
PEGASUS_TIMEOUT=3600

# Default min signal in dBm (default: -80)
PEGASUS_MIN_SIGNAL=-80

# Cache directory for scan results (default: ~/.pegasus_nexus/scans)
PEGASUS_CACHE_DIR=~/.pegasus_nexus/scans

# Tool paths (uncomment to override defaults)
# PEGASUS_AIRCRACK_PATH=/usr/bin/aircrack-ng
# PEGASUS_HASHCAT_PATH=/usr/bin/hashcat
# PEGASUS_CRUNCH_PATH=/usr/bin/crunch
